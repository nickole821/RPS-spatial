Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"fitO", "[", 
    RowBox[{"o_", ",", "y_", ",", "B_"}], "]"}], ":=", 
   RowBox[{"o", "+", 
    RowBox[{
     RowBox[{"1", "/", "2"}], "*", "y"}], "+", 
    RowBox[{"2", "*", "B"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fitY", "[", 
    RowBox[{"o_", ",", "y_", ",", "B_", ",", "c_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"2", "*", "o"}], "+", "y", "+", 
    RowBox[{"c", "*", "B"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fitB", "[", 
     RowBox[{"o_", ",", "y_", ",", "B_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"o", "*", 
      RowBox[{"1", "/", "2"}]}], "+", 
     RowBox[{"2", "*", "y"}], "+", "B"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fitmedio", "[", 
     RowBox[{"o_", ",", "y_", ",", "B_", ",", "c_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"fitO", "[", 
       RowBox[{"o", ",", "y", ",", "B"}], "]"}], "*", "o"}], "+", 
     RowBox[{
      RowBox[{"fitY", "[", 
       RowBox[{"o", ",", "y", ",", "B", ",", "c"}], "]"}], "*", "y"}], "+", 
     RowBox[{
      RowBox[{"fitB", "[", 
       RowBox[{"o", ",", "y", ",", "B"}], "]"}], "*", "B"}]}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dodt", "[", 
     RowBox[{"o_", ",", "y_", ",", "B_", ",", "c_"}], "]"}], ":=", 
    RowBox[{"o", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"fitO", "[", 
        RowBox[{"o", ",", "y", ",", "B"}], "]"}], "-", 
       RowBox[{"fitmedio", "[", 
        RowBox[{"o", ",", "y", ",", "B", ",", "c"}], "]"}]}], ")"}]}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dydt", "[", 
     RowBox[{"o_", ",", "y_", ",", "B_", ",", "c_"}], "]"}], ":=", 
    RowBox[{"y", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"fitY", "[", 
        RowBox[{"o", ",", "y", ",", "B", ",", "c"}], "]"}], "-", 
       RowBox[{"fitmedio", "[", 
        RowBox[{"o", ",", "y", ",", "B", ",", "c"}], "]"}]}], ")"}]}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dbdt", "[", 
    RowBox[{"o_", ",", "y_", ",", "B_", ",", "c_"}], "]"}], ":=", 
   RowBox[{"B", "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"fitB", "[", 
       RowBox[{"o", ",", "y", ",", "B"}], "]"}], "-", 
      RowBox[{"fitmedio", "[", 
       RowBox[{"o", ",", "y", ",", "B", ",", "c"}], "]"}]}], ")"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9827647157692814`*^9, 3.9827648644319744`*^9}, {
