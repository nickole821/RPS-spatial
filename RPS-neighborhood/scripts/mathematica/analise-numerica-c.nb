      RowBox[{"o", ",", "y", ",", "B"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "200"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
