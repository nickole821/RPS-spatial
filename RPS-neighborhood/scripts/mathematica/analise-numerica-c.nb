       RowBox[{"y", "[", "t", "]"}], ",", 
       RowBox[{"B", "[", "t", "]"}]}], "}"}], "/.", " ", "sol1"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "200"}], "}"}], ",", 
   RowBox[{"PlotLegends", "->", 
