          RowBox[{"B", "[", "t", "]"}], ",", "c"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"B", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"dbdt", "[", 
         RowBox[{
          RowBox[{"o", "[", "t", "]"}], ",", 
          RowBox[{"y", "[", "t", "]"}], ",", 
          RowBox[{"B", "[", "t", "]"}], ",", "c"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"o", "[", "0", "]"}], "==", "0.333"}], ",", 
