          RowBox[{"y", "[", "t", "]"}], ",", 
          RowBox[{"B", "[", "t", "]"}], ",", "c"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"B", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"dbdt", "[", 
