Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bt", "[", "t_", "]"}], ":=", 
   RowBox[{"1", "-", 
    RowBox[{"ot", "[", "t", "]"}], "-", 
    RowBox[{"yt", "[", "t", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fitOteste", "=", 
   RowBox[{
    RowBox[{"ot", "[", "t", "]"}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "2"}], ")"}], "*", 
      RowBox[{"yt", "[", "t", "]"}]}], ")"}], "+", 
    RowBox[{"2", "*", 
     RowBox[{"bt", "[", "t", "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"fitYteste", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"2", "-", "0.5"}], ")"}], "*", 
      RowBox[{"ot", "[", "t", "]"}]}], ")"}], "+", 
    RowBox[{"yt", "[", "t", "]"}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"2", "-", "0.8"}], ")"}], "*", 
      RowBox[{"bt", "[", "t", "]"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fitBteste", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"ot", "[", "t", "]"}], "*", 
       RowBox[{"1", "/", "2"}]}], ")"}], "+", 
     RowBox[{"(", 
      RowBox[{"2", "*", 
       RowBox[{"yt", "[", "t", "]"}]}], ")"}], "+", 
     RowBox[{"bt", "[", "t", "]"}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fitmedioteste", "=", 
    RowBox[{
     RowBox[{"fitOteste", "*", 
      RowBox[{"ot", "[", "t", "]"}]}], "+", 
     RowBox[{"fitYteste", "*", 
      RowBox[{"yt", "[", "t", "]"}]}], "+", 
     RowBox[{"fitBteste", "*", 
      RowBox[{"bt", "[", "t", "]"}]}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"odot", "=", 
   RowBox[{
    RowBox[{"ot", "[", "t", "]"}], "*", 
    RowBox[{"(", 
     RowBox[{"fitOteste", "-", "fitmedioteste"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ydot", "=", 
    RowBox[{
     RowBox[{"yt", "[", "t", "]"}], "*", 
     RowBox[{"(", 
      RowBox[{"fitYteste", "-", "fitmedioteste"}], ")"}]}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
