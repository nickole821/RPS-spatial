Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"mat7", "=", 
     RowBox[{"jacobiana", "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"o", "\[Rule]", 
         FractionBox[
          RowBox[{
           RowBox[{"-", "1"}], "+", "b"}], 
          RowBox[{
           RowBox[{"-", "2"}], "+", 
           RowBox[{"2", " ", "b"}], "-", "c"}]]}], ",", 
        RowBox[{"y", "\[Rule]", "0"}], ",", 
        RowBox[{"B", "\[Rule]", 
         FractionBox[
          RowBox[{
           RowBox[{"-", "1"}], "+", "b", "-", "c"}], 
          RowBox[{
           RowBox[{"-", "2"}], "+", 
           RowBox[{"2", " ", "b"}], "-", "c"}]]}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"autovalores7", "=", 
    RowBox[{"Eigenvalues", "[", "mat7", "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"Resolve", "[", 
    RowBox[{"Exists", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"b", ",", "c"}], "}"}], ",", 
      RowBox[{
       RowBox[{"b", ">=", "1"}], "&&", 
       RowBox[{"c", ">=", "0"}], "&&", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "1"}], "+", "b", "-", "c"}], "<=", "0"}], " ", "&&", 
       " ", 
       RowBox[{"0", "<=", 
        FractionBox[
         RowBox[{
          RowBox[{"-", "1"}], "+", "b", "-", "c"}], 
         RowBox[{
          RowBox[{"-", "2"}], "+", 
          RowBox[{"2", " ", "b"}], "-", "c"}]], "<=", "1"}], " ", "&&", " ", 
       RowBox[{"0", "<=", " ", 
        FractionBox[
         RowBox[{
          RowBox[{"-", "1"}], "+", "b"}], 
         RowBox[{
          RowBox[{"-", "2"}], "+", 
          RowBox[{"2", " ", "b"}], "-", "c"}]], "<=", "1"}], " ", "&&", " ", 
       RowBox[{
        RowBox[{"Max", "[", 
         RowBox[{"Re", "[", "autovalores7", "]"}], "]"}], "<", "0"}]}]}], 
     "]"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"region7", " ", "=", " ", 
    RowBox[{"Reduce", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"b", ">=", "1"}], "&&", 
       RowBox[{"c", ">=", "0"}], "&&", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "1"}], "+", "b", "-", "c"}], "<=", "0"}], "&&", 
       RowBox[{
        RowBox[{"Max", "[", 
         RowBox[{"Re", "[", "autovalores7", "]"}], "]"}], "<", "0"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"b", ",", "c"}], "}"}], ",", "Reals"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"RegionPlot", "[", 
    RowBox[{
     RowBox[{"region7", " ", "&&", 
      RowBox[{
       RowBox[{"Max", "[", 
        RowBox[{"Re", "[", "autovalores7", "]"}], "]"}], "<", "0"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"b", ",", "1", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"c", ",", "0", ",", "2"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", 
        RowBox[{"Opacity", "[", "1", "]"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotLegends", "->", "\"\<Expressions\>\""}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<b\>\"", ",", "\"\<c\>\""}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
     "PlotLabel", 
      "->", "\"\<Regi\[ATilde]o de estabilidade com duas \
estrat\[EAcute]gias\>\""}]}], "]"}]}]}]], "Input",
