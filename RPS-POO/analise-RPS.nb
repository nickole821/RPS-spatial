Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"region5", " ", "=", " ", 
  RowBox[{"Reduce", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"b", ">", "1"}], "&&", 
     RowBox[{"c", ">", "0"}], "&&", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "1"}], "+", "b", "-", "c"}], "<", "0"}], "&&", 
     RowBox[{
      RowBox[{"Max", "[", 
       RowBox[{"Re", "[", "autovalores5", "]"}], "]"}], "<", "0"}]}], ",", 
    RowBox[{"{", 
