Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mat5", "=", 
   RowBox[{"jacobiana", "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"o", "\[Rule]", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "1"}], "+", "b", "-", "c"}], 
        RowBox[{
         RowBox[{"-", "2"}], "+", 
         RowBox[{"2", " ", "b"}], "-", "c"}]]}], ",", 
      RowBox[{"y", "\[Rule]", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "1"}], "+", "b"}], 
        RowBox[{
         RowBox[{"-", "2"}], "+", 
         RowBox[{"2", " ", "b"}], "-", "c"}]]}], ",", 
      RowBox[{"B", "\[Rule]", "0"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"autovalores5", "=", 
  RowBox[{"Eigenvalues", "[", "mat5", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Resolve", "[", 
  RowBox[{"Exists", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"b", ",", "c"}], "}"}], ",", 
    RowBox[{
     RowBox[{"b", ">=", "1"}], "&&", 
     RowBox[{"c", ">=", "0"}], "&&", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "1"}], "+", "b", "-", "c"}], "<=", "0"}], " ", "&&", " ", 
     RowBox[{"0", "<=", " ", 
      FractionBox[
       RowBox[{
        RowBox[{"-", "1"}], "+", "b", "-", "c"}], 
       RowBox[{
        RowBox[{"-", "2"}], "+", 
        RowBox[{"2", " ", "b"}], "-", "c"}]], " ", "<=", "1"}], " ", "&&", 
     " ", 
     RowBox[{"0", "<=", 
      FractionBox[
       RowBox[{
        RowBox[{"-", "1"}], "+", "b"}], 
       RowBox[{
        RowBox[{"-", "2"}], "+", 
        RowBox[{"2", " ", "b"}], "-", "c"}]], "<=", "1"}], " ", "&&", " ", 
     RowBox[{
      RowBox[{"Max", "[", 
       RowBox[{"Re", "[", "autovalores5", "]"}], "]"}], "<", "0"}]}]}], "]"}],
   "]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.969439423773655*^9, 3.9694394565220184`*^9}, {
  3.9699537312695293`*^9, 3.969953788919548*^9}},
 CellLabel->"In[49]:=",ExpressionUUID->"ef1eee19-b720-2843-937b-4636d3ea48dd"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox[
    RowBox[{"1", "-", 
     SuperscriptBox["b", "2"], "+", 
     RowBox[{"b", " ", "c"}]}], 
    RowBox[{
     RowBox[{"-", "2"}], "+", 
     RowBox[{"2", " ", "b"}], "-", "c"}]], ",", 
   FractionBox[
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     RowBox[{"2", " ", "b"}], "-", 
     SuperscriptBox["b", "2"], "-", "c", "+", 
     RowBox[{"b", " ", "c"}]}], 
    RowBox[{
     RowBox[{"-", "2"}], "+", 
     RowBox[{"2", " ", "b"}], "-", "c"}]], ",", 
   FractionBox[
    RowBox[{"1", "-", 
     RowBox[{"2", " ", "b"}], "+", 
     SuperscriptBox["b", "2"], "+", "c", "-", 
