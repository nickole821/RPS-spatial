Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Ponto", " ", "3", " ", "estrat\[EAcute]gias"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"plotMix", "=", 
     RowBox[{"RegionPlot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"b", ">", "1"}], "&&", 
        RowBox[{"c", ">", "0"}], "&&", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "+", "b", "-", "c"}], "<", "0"}], " ", "&&", 
        RowBox[{
         RowBox[{"Max", "[", 
          RowBox[{"Re", "[", "autovalores4", "]"}], "]"}], "<", "0"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"b", ",", "1", ",", "4"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", "0", ",", "4"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Purple", ",", 
          RowBox[{"Opacity", "[", "0.5", "]"}]}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"BoundaryStyle", "->", "None"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"Placed", "[", 
         RowBox[{
          RowBox[{"{", "\"\<Est\[AAcute]vel coexist\[EHat]ncia 3\>\"", "}"}], 
          ",", "Below"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"Ponto", " ", "com", " ", "duas", " ", "estrat\[EAcute]gias"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plotOY", "=", 
     RowBox[{"RegionPlot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"b", ">", "1"}], "&&", 
        RowBox[{"c", ">", "0"}], "&&", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "+", "b", "-", "c"}], "<", "0"}], "&&", " ", 
        RowBox[{"0", "<=", 
         FractionBox[
          RowBox[{
           RowBox[{"-", "1"}], "+", "b", "-", "c"}], 
          RowBox[{
           RowBox[{"-", "2"}], "+", 
           RowBox[{"2", " ", "b"}], "-", "c"}]], "<=", "1"}], "&&", 
        RowBox[{"0", "<=", 
         FractionBox[
          RowBox[{
           RowBox[{"-", "1"}], "+", "b"}], 
          RowBox[{
           RowBox[{"-", "2"}], "+", 
           RowBox[{"2", " ", "b"}], "-", "c"}]], "<=", "1"}], "&&", 
        RowBox[{
         RowBox[{"Max", "[", 
