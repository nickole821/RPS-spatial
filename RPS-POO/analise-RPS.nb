Cell[BoxData[{
 RowBox[{
  RowBox[{"mat4", "=", 
   RowBox[{"jacobiana", "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"o", "\[Rule]", 
       FractionBox["1", "3"]}], ",", 
      RowBox[{"y", "\[Rule]", 
