Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mat6", "=", 
   RowBox[{"jacobiana", "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"o", "\[Rule]", "0"}], ",", 
      RowBox[{"y", "\[Rule]", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "1"}], "+", "b", "-", "c"}], 
        RowBox[{
         RowBox[{"-", "2"}], "+", 
         RowBox[{"2", " ", "b"}], "-", "c"}]]}], ",", 
      RowBox[{"B", "\[Rule]", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "1"}], "+", "b"}], 
        RowBox[{
         RowBox[{"-", "2"}], "+", 
         RowBox[{"2", " ", "b"}], "-", "c"}]]}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"autovalores6", "=", 
  RowBox[{"Eigenvalues", "[", "mat6", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Resolve", "[", 
  RowBox[{"Exists", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"b", ",", "c"}], "}"}], ",", 
    RowBox[{
     RowBox[{"b", ">=", "1"}], "&&", 
     RowBox[{"c", ">=", "0"}], "&&", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "1"}], "+", "b", "-", "c"}], "<=", "0"}], " ", "&&", 
     RowBox[{"0", "<=", 
      FractionBox[
       RowBox[{
        RowBox[{"-", "1"}], "+", "b", "-", "c"}], 
       RowBox[{
        RowBox[{"-", "2"}], "+", 
        RowBox[{"2", " ", "b"}], "-", "c"}]], "<=", "1"}], " ", "&&", " ", 
     RowBox[{"0", "<=", " ", 
      FractionBox[
       RowBox[{
        RowBox[{"-", "1"}], "+", "b"}], 
       RowBox[{
        RowBox[{"-", "2"}], "+", 
        RowBox[{"2", " ", "b"}], "-", "c"}]], "<=", "1"}], " ", "&&", " ", 
     RowBox[{
      RowBox[{"Max", "[", 
       RowBox[{"Re", "[", "autovalores6", "]"}], "]"}], "<", "0"}]}]}], "]"}],
   "]"}], "\[IndentingNewLine]", 
 RowBox[{"region6", " ", "=", " ", 
  RowBox[{"Reduce", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"b", ">=", "1"}], "&&", 
     RowBox[{"c", ">=", "0"}], "&&", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "1"}], "+", "b", "-", "c"}], "<=", "0"}], "&&", 
     RowBox[{
      RowBox[{"Max", "[", 
       RowBox[{"Re", "[", "autovalores6", "]"}], "]"}], "<", "0"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"b", ",", "c"}], "}"}], ",", "Reals"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"RegionPlot", "[", 
  RowBox[{
   RowBox[{"region6", " ", "&&", 
    RowBox[{
     RowBox[{"Max", "[", 
      RowBox[{"Re", "[", "autovalores6", "]"}], "]"}], "<", "0"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"b", ",", "1", ",", "3"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"c", ",", "0", ",", "2"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotStyle", "->", 
    RowBox[{"{", 
     RowBox[{"Blue", ",", 
      RowBox[{"Opacity", "[", "1", "]"}]}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotLegends", "->", "\"\<Expressions\>\""}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<b\>\"", ",", "\"\<c\>\""}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
   "PlotLabel", 
    "->", "\"\<Regi\[ATilde]o de estabilidade com duas \
estrat\[EAcute]gias\>\""}]}], "]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.9694446169089336`*^9, 3.969444698106127*^9}, 
   3.9694447587388477`*^9, {3.969953838952959*^9, 3.9699538848974285`*^9}},
