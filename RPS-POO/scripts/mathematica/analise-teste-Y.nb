Cell[BoxData[{
 RowBox[{
  RowBox[{"mat3", "=", 
   RowBox[{"jacobiana", "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"o", "\[Rule]", 
       RowBox[{"-", 
        FractionBox[
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "5"}], "+", 
            RowBox[{"3", " ", "b"}]}], ")"}]}], 
         RowBox[{"5", "+", 
          RowBox[{"10", " ", "a"}], "-", 
          RowBox[{"8", " ", "b"}]}]]}]}], ",", 
      RowBox[{"y", "\[Rule]", 
       FractionBox[
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", "a"}], "-", "b"}], ")"}]}], 
        RowBox[{"5", "+", 
         RowBox[{"10", " ", "a"}], "-", 
         RowBox[{"8", " ", "b"}]}]]}], ",", 
      RowBox[{"B", "\[Rule]", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "5"}], "+", 
         RowBox[{"6", " ", "a"}]}], 
        RowBox[{"5", "+", 
         RowBox[{"10", " ", "a"}], "-", 
         RowBox[{"8", " ", "b"}]}]]}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"autovalores3", "=", 
  RowBox[{"Eigenvalues", "[", "mat3", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Resolve", "[", 
  RowBox[{
   RowBox[{"Exists", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}], ",", 
     RowBox[{
      RowBox[{"a", ">=", "1"}], "&&", 
      RowBox[{"b", ">=", "0"}], " ", "&&", " ", 
      RowBox[{"b", " ", "<=", "1"}], "&&", " ", 
      RowBox[{
       RowBox[{"a", "-", "b"}], ">=", "0"}], " ", "&&", " ", 
      RowBox[{
       RowBox[{"Max", "[", 
        RowBox[{"Re", "[", "autovalores3", "]"}], "]"}], "<", "0"}]}]}], 
    "]"}], ",", " ", "Reals"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Reduce", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"a", ">=", "1"}], "&&", 
    RowBox[{"b", ">=", "0"}], " ", "&&", " ", 
    RowBox[{"b", " ", "<=", "1"}], "&&", " ", 
    RowBox[{
     RowBox[{"a", "-", "b"}], ">=", "0"}], " ", "&&", " ", 
    RowBox[{
     RowBox[{"Max", "[", 
      RowBox[{"Re", "[", "autovalores3", "]"}], "]"}], "<", "0"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"a", ",", "b"}], "}"}], ",", "Reals"}], "]"}]}], "Input",
