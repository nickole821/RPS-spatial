Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"region3", " ", "=", " ", 
   RowBox[{"Reduce", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"a", ">=", "1"}], "&&", 
      RowBox[{"b", ">=", "0"}], " ", "&&", " ", 
      RowBox[{
       RowBox[{"a", "-", "b"}], ">=", "0"}], " ", "&&", " ", 
      RowBox[{
       RowBox[{"Max", "[", 
        RowBox[{"Re", "[", "autovalores3", "]"}], "]"}], "<", "0"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}], ",", "Reals"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"RegionPlot", "[", 
  RowBox[{
   RowBox[{"region3", "&&", 
    RowBox[{
     RowBox[{"Max", "[", 
      RowBox[{"Re", "[", "autovalores3", "]"}], "]"}], "<", "0"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"a", ",", "0", ",", "5"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"b", ",", "0", ",", "5"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotStyle", "->", 
    RowBox[{"{", 
     RowBox[{"Blue", ",", 
      RowBox[{"Opacity", "[", "1", "]"}]}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"BoundaryStyle", "->", "None"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotLegends", "->", "\"\<Expressions\>\""}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<a\>\"", ",", "\"\<b\>\""}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
   "PlotLabel", 
    "->", "\"\<Regi\[ATilde]o de estabilidade com tr\[EHat]s \
estrat\[EAcute]gias\>\""}]}], "]"}]}], "Input",
