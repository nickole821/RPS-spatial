Cell[BoxData[{
 RowBox[{
  RowBox[{"equilibria", "=", 
   RowBox[{"FindInstance", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"dodt2", "[", 
         RowBox[{"o", ",", "y"}], "]"}], "==", "0"}], ",", 
       RowBox[{
        RowBox[{"dydt2", "[", 
         RowBox[{"o", ",", "y"}], "]"}], "==", "0"}], ",", 
       RowBox[{"o", ">=", "0"}], ",", 
       RowBox[{"y", ">=", "0"}], ",", 
       RowBox[{
        RowBox[{"o", "+", "y"}], "<=", "1"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"o", ",", "y"}], "}"}], ",", "Reals", ",", "20"}], "]"}]}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"V\[EAcute]rtices", " ", "do", " ", "tri\[AHat]ngulo"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vO", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"vY", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"1", "/", "2"}], ",", 
     RowBox[{
      RowBox[{"Sqrt", "[", "3", "]"}], "/", "2"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"vB", "=", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"maxNorm", "=", 
    RowBox[{"Max", "[", 
     RowBox[{"Flatten", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Norm", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"dodt2", "[", 
            RowBox[{"o", ",", "y"}], "]"}], ",", 
           RowBox[{"dydt2", "[", 
            RowBox[{"o", ",", "y"}], "]"}]}], "}"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"o", ",", "0", ",", "1", ",", "0.02"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", "0", ",", 
          RowBox[{"1", "-", "o"}], ",", "0.02"}], "}"}]}], "]"}], "]"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"colorFunc", "[", 
     RowBox[{"o_", ",", "y_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"ColorData", "[", "\"\<Rainbow\>\"", "]"}], "[", 
     RowBox[{
      RowBox[{"Norm", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"dodt2", "[", 
          RowBox[{"o", ",", "y"}], "]"}], ",", 
         RowBox[{"dydt2", "[", 
          RowBox[{"o", ",", "y"}], "]"}]}], "}"}], "]"}], "/", "maxNorm"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Converte", " ", 
     RowBox[{"(", 
      RowBox[{"o", ",", "y"}], ")"}]}], "->", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"x", ",", "y"}], ")"}], " ", "do", " ", "tri\[AHat]ngulo"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"barycentricToCartesian", "[", 
     RowBox[{"o_", ",", "y_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"o", "*", "vO"}], "+", 
     RowBox[{"y", "*", "vY"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "o", "-", "y"}], ")"}], "*", "vB"}]}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Gera", " ", "setas", " ", "do", " ", "campo"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"field", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"pt", ",", "vec", ",", "normvec"}], "}"}], ",", 
        RowBox[{
         RowBox[{"pt", "=", 
          RowBox[{"barycentricToCartesian", "[", 
           RowBox[{"o", ",", "y"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"vec", "=", 
          RowBox[{
           RowBox[{"barycentricToCartesian", "[", 
            RowBox[{
