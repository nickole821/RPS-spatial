         "\[IndentingNewLine]", 
         RowBox[{"normvec", "=", 
          RowBox[{"0.01", "*", 
           RowBox[{"Normalize", "[", "vec", "]"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"colorFunc", "[", 
