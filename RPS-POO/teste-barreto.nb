Cell[BoxData[{
 RowBox[{
  RowBox[{"fitO", "=", 
   RowBox[{
    RowBox[{"o", "[", "t", "]"}], "+", 
    RowBox[{"0.5", "*", 
     RowBox[{"y", "[", "t", "]"}]}], "+", 
    RowBox[{"4.5", "*", 
     RowBox[{"B", "[", "t", "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"fitY", "=", 
   RowBox[{
    RowBox[{"2", "*", 
     RowBox[{"o", "[", "t", "]"}]}], "+", 
    RowBox[{"y", "[", "t", "]"}], "+", 
    RowBox[{"0.9999", "*", 
     RowBox[{"B", "[", "t", "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fitB", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"o", "[", "t", "]"}], "*", "0.5"}], "+", 
     RowBox[{"2", "*", 
      RowBox[{"y", "[", "t", "]"}]}], "+", 
     RowBox[{"B", "[", "t", "]"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fitmedio", "=", 
    RowBox[{
     RowBox[{"fitO", "*", 
      RowBox[{"o", "[", "t", "]"}]}], "+", 
     RowBox[{"fitY", "*", 
      RowBox[{"y", "[", "t", "]"}]}], "+", 
     RowBox[{"fitB", "*", 
      RowBox[{"B", "[", "t", "]"}]}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dodt", "=", 
   RowBox[{
    RowBox[{"o", "[", "t", "]"}], "*", 
    RowBox[{"(", 
     RowBox[{"fitO", "-", "fitmedio"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dydt", "=", 
   RowBox[{
    RowBox[{"y", "[", "t", "]"}], "*", 
    RowBox[{"(", 
     RowBox[{"fitY", "-", "fitmedio"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"dbdt", "=", 
    RowBox[{
     RowBox[{"B", "[", "t", "]"}], "*", 
     RowBox[{"(", 
      RowBox[{"fitB", "-", "fitmedio"}], ")"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"sol", " ", "=", " ", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"o", "'"}], "[", "t", "]"}], "==", "dodt"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "'"}], "[", "t", "]"}], "==", "dydt"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"B", "'"}], "[", "t", "]"}], "==", "dbdt"}], ",", 
      RowBox[{
       RowBox[{"o", "[", "0", "]"}], "==", "0.4"}], ",", 
      RowBox[{
       RowBox[{"y", "[", "0", "]"}], "==", "0.15"}], ",", 
      RowBox[{
       RowBox[{"B", "[", "0", "]"}], "==", "0.45"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"o", ",", "y", ",", "B"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "200"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"o", "[", "t", "]"}], "/.", " ", 
      RowBox[{"sol", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ",", 
     RowBox[{
      RowBox[{"y", "[", "t", "]"}], "/.", " ", 
      RowBox[{"sol", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ",", 
     RowBox[{
      RowBox[{"B", "[", "t", "]"}], "/.", " ", 
      RowBox[{"sol", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "200"}], "}"}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<o\>\"", ",", "\"\<y\>\"", ",", "\"\<B\>\""}], "}"}]}]}], 
